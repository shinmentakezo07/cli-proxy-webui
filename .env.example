# Example environment for the root (panel + backend) Docker Compose stack.
# Copy to .env and uncomment/adjust as needed.

# ---- Image tag for the backend image (built from ./CLIProxyAPI) ----
# CLI_PROXY_IMAGE=cliproxy-backend:local

# ---- Build-time version metadata (optional) ----
# VERSION=dev
# COMMIT=none
# BUILD_DATE=unknown

# ---- Mounted paths (config / OAuth auth material / logs) ----
# These host paths are bind-mounted into the backend container.
# CLI_PROXY_CONFIG_PATH=./CLIProxyAPI/config.yaml
# CLI_PROXY_AUTH_PATH=./CLIProxyAPI/auths
# CLI_PROXY_LOG_PATH=./CLIProxyAPI/logs

# ----------------------------------------------------------------------------
# Management access notes (set in ./CLIProxyAPI/config.yaml, NOT here)
# ----------------------------------------------------------------------------
# The panel and the API share a single public port (8317) and origin, so the
# SPA connects with zero configuration. Management access is still gated by the
# backend:
#   remote-management:
#     secret-key: "<a-strong-management-key>"   # ALWAYS required (localhost or remote)
#     allow-remote: true                         # REQUIRED for browsers NOT on the host,
#                                                 # because nginx fronts the backend (the
#                                                 # server sees the real client IP via
#                                                 # X-Forwarded-For, so non-localhost
#                                                 # clients are "remote"). Localhost
#                                                 # browsers can use allow-remote: false.
# To create config.yaml from the bundled template:
#   cp ./CLIProxyAPI/config.example.yaml ./CLIProxyAPI/config.yaml
